# Ignore bazel artifact symlinks at repo root
/bazel-*
MODULE.bazel.lock

# Ignore python cache files
**/__pycache__

# Ignore helm chart lock files and downloaded dependencies
*.tgz
**/Chart.lock

# Ignore Intelij config files
.idea

