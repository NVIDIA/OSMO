{
  "pod_group": {
    "apiVersion": "scheduling.run.ai/v2alpha2",
    "kind": "PodGroup",
    "metadata": {
      "labels": {
        "kai.scheduler/queue": "osmo-pool-osmo-test-gpus",
        "osmo.group_uuid": "group-xyz",
        "osmo.workflow_id": "wf-abc",
        "runai/queue": "osmo-pool-osmo-test-gpus"
      },
      "name": "group-xyz"
    },
    "spec": {
      "priorityClassName": "osmo-high",
      "queue": "osmo-pool-osmo-test-gpus",
      "subGroups": [
        {
          "minMember": 2,
          "name": "z1-r1",
          "topologyConstraint": {
            "requiredTopologyLevel": "topology.kubernetes.io/rack",
            "topology": "osmo-pool-osmo-test-gpus-topology"
          }
        },
        {
          "minMember": 1,
          "name": "z1-r2",
          "topologyConstraint": {
            "requiredTopologyLevel": "topology.kubernetes.io/rack",
            "topology": "osmo-pool-osmo-test-gpus-topology"
          }
        }
      ],
      "topologyConstraint": {
        "requiredTopologyLevel": "topology.kubernetes.io/zone",
        "topology": "osmo-pool-osmo-test-gpus-topology"
      }
    }
  },
  "pods": [
    {
      "apiVersion": "v1",
      "kind": "Pod",
