          "kai.scheduler/subgroup-name": "z1-r1",
          "osmo.group_uuid": "group-xyz",
          "osmo.task_name": "worker_0",
          "osmo.workflow_id": "wf-abc",
          "runai/queue": "osmo-pool-osmo-test-gpus"
        },
        "name": "wf-abc-task-0"
      },
      "spec": {
        "containers": [
          {
            "image": "nvcr.io/example/user:1.0",
            "name": "user",
            "resources": {
              "limits": {
                "cpu": "4",
                "memory": "16Gi",
                "nvidia.com/gpu": "1"
              },
              "requests": {
                "cpu": "4",
                "memory": "16Gi",
                "nvidia.com/gpu": "1"
              }
            }
          }
        ],
        "restartPolicy": "Never",
        "schedulerName": "kai-scheduler"
      }
    },
    {
