# Multi-stage build: golang:1.22 → distroless.
#
# Build context expected to be the taskgroup/ directory:
#   docker build -f deploy/Dockerfile.controller -t osmo-taskgroup-controller:v0.1.0 .

# Build stage runs on the host's native arch (no --platform). Go's cross-compiler
# handles the GOOS/GOARCH switch, so only the (tiny) final image stage needs the
# target arch pinned. Build with TARGETARCH=amd64 to produce amd64 output without
# emulating the Go toolchain.
FROM docker.io/library/golang:1.22 AS build
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
ARG TARGETOS=linux
ARG TARGETARCH=amd64
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -trimpath -ldflags='-s -w' -o /out/controller ./cmd/controller

FROM --platform=linux/amd64 gcr.io/distroless/static:nonroot
WORKDIR /
COPY --from=build /out/controller /controller
USER 65532:65532
ENTRYPOINT ["/controller"]
